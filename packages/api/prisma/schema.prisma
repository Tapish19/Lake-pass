generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Marina {
  id              String        @id @default(cuid())
  name            String
  lake            String
  address         String
  city            String
  state           String
  latitude        Float?
  longitude       Float?
  phone           String?
  website         String?
  logoUrl         String?
  isActive        Boolean       @default(true)
  stripeAccountId String?
  widgetColor     String?       @default("#1d6fdb")
  widgetFont      String?       @default("system-ui")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  boats           Boat[]
  staff           StaffMember[]
  invites         StaffInvite[]

  @@map("marinas")
}

model Boat {
  id               String     @id @default(cuid())
  marinaId         String
  name             String
  type             String
  capacity         Int
  dailyRate        Float
  hourlyRate       Float?
  description      String?
  amenities        String[]
  photoUrls        String[]
  isActive         Boolean    @default(true)
  status           BoatStatus @default(available)
  // Minutes of buffer required between reservations (e.g. 60 = 1h turnaround)
  turnaroundBuffer Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  marina           Marina         @relation(fields: [marinaId], references: [id])
  reservations     Reservation[]
  reviews          Review[]
  blockouts        Blockout[]
  favorites        Favorite[]
  maintenanceLogs  MaintenanceLog[]

  @@map("boats")
}

enum BoatStatus {
  available
  booked
  maintenance
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  name         String
  email        String   @unique
  phone        String?
  licenseUrl   String?
  insuranceUrl String?
  pushToken    String?
  // Emergency contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  // Stripe customer ID for saved payment methods
  stripeCustomerId         String?
  // GDPR/CCPA compliance
  deletedAt             DateTime?
  dataExportRequestedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservations Reservation[]
  reviews      Review[]
  favorites    Favorite[]

  @@map("users")
}

model StaffMember {
  id       String    @id @default(cuid())
  marinaId String
  clerkId  String    @unique
  role     StaffRole @default(staff)

  marina   Marina    @relation(fields: [marinaId], references: [id])

  @@map("staff_members")
}

model StaffInvite {
  id        String    @id @default(cuid())
  marinaId  String
  email     String
  role      StaffRole @default(staff)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  marina Marina @relation(fields: [marinaId], references: [id])

  @@index([marinaId])
  @@index([email])
  @@map("staff_invites")
}

enum StaffRole {
  owner
  manager
  staff
}

model Addon {
  id          String   @id @default(cuid())
  marinaId    String
  name        String
  price       Float
  description String?
  createdAt   DateTime @default(now())

  reservationAddons ReservationAddon[]

  @@map("addons")
}

model Reservation {
  id              String            @id @default(cuid())
  boatId          String
  userId          String
  startDate       DateTime
  endDate         DateTime
  status          ReservationStatus @default(pending)
  paymentStatus   PaymentStatus     @default(unpaid)
  rentalAmount    Float?
  addonAmount     Float?
  platformFee     Float?
  totalAmount     Float?
  depositAmount   Float?
  notes           String?
  walkInName      String?
  walkInPhone     String?
  walkInEmail     String?
  // Waiver
  waiverSignedAt      DateTime?
  waiverIpAddress     String?
  waiverSignerName    String?
  waiverVersion       String?
  waiverTextSnapshot  String?
  // Stripe
  stripeSessionId         String?
  securityDepositHoldId   String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  boat             Boat               @relation(fields: [boatId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  addons           ReservationAddon[]
  notifications    NotificationLog[]

  @@map("reservations")
}

model ReservationAddon {
  id            String @id @default(cuid())
  reservationId String
  addonId       String
  name          String
  price         Float

  reservation Reservation @relation(fields: [reservationId], references: [id])
  addon       Addon       @relation(fields: [addonId], references: [id])

  @@map("reservation_addons")
}

enum ReservationStatus {
  pending
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

enum PaymentStatus {
  unpaid
  deposit_paid
  paid
  refunded
  partially_refunded
}

model Review {
  id        String   @id @default(cuid())
  boatId    String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  boat Boat @relation(fields: [boatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([boatId, userId])
  @@map("reviews")
}

model Blockout {
  id        String   @id @default(cuid())
  boatId    String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())

  boat Boat @relation(fields: [boatId], references: [id])

  @@map("blockouts")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  boatId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  boat Boat @relation(fields: [boatId], references: [id])

  @@unique([userId, boatId])
  @@map("favorites")
}

model NotificationLog {
  id            String   @id @default(cuid())
  reservationId String
  type          String
  channel       String
  recipient     String
  sentAt        DateTime @default(now())
  error         String?

  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@map("notification_logs")
}

model ComplianceRequest {
  id          String   @id @default(cuid())
  userId      String
  type        String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  completedAt DateTime?
  notes       String?

  @@index([userId])
  @@map("compliance_requests")
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  boatId      String
  type        String
  notes       String?
  cost        Float?
  performedAt DateTime @default(now())
  performedBy String?
  createdAt   DateTime @default(now())

  boat Boat @relation(fields: [boatId], references: [id])

  @@map("maintenance_logs")
}
