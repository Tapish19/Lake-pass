    "express-rate-limit": "^7.5.0",
    "@clerk/backend": "^1.18.0",
    "@lake-pass/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "stripe": "^15.0.0",
    "twilio": "^5.0.0",
    "zod": "^3.23.0",
    "@sendgrid/mail": "^8.1.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "papaparse": "^5.4.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.0.0",
